<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo del widget de acceso rápido (issue #10): degradado oscuro entre
     AppColors.backgroundDark y AppColors.surfaceDark (lib/styles/colors.dart),
     a juego con el tema oscuro de la app. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#FF1E1E1E"
        android:endColor="#FF121212"
        android:angle="135" />
    <corners android:radius="20dp" />
    <!-- Borde sutil en AppColors.primary, para no perder del todo la
         identidad de marca al pasar a fondo oscuro. -->
    <stroke
        android:width="1dp"
        android:color="#4D1E88E5" />
</shape>
